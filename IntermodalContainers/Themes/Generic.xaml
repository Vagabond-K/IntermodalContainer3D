<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:local="clr-namespace:IntermodalContainers">

    <Style x:Key="SurfacePresenter" TargetType="ContentPresenter">
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    
    <Style x:Key="SurfaceDecolor" TargetType="Rectangle">
        <Setter Property="StrokeThickness" Value="80"/>
        <Setter Property="Stroke" Value="White"/>
        <Setter Property="Opacity" Value="0.23"/>
        <Setter Property="Margin" Value="-40"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="150"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="SideCorner" TargetType="Rectangle">
        <Setter Property="Width" Value="17.8"/>
        <Setter Property="Height" Value="11.8"/>
        <Setter Property="Fill" Value="#40802E00"/>
        <Setter Property="Stroke" Value="#80000000"/>
        <Setter Property="StrokeThickness" Value="0.2"/>
        <Setter Property="Margin" Value="-0.4"/>
    </Style>
    
    <Style x:Key="SideHole" TargetType="Rectangle">
        <Setter Property="Width" Value="5"/>
        <Setter Property="Height" Value="7"/>
        <Setter Property="RadiusX" Value="2.5"/>
        <Setter Property="RadiusY" Value="2.5"/>
        <Setter Property="Fill" Value="Black"/>
        <Setter Property="Margin" Value="6.4,2"/>
    </Style>
    
    <Style x:Key="FrontCorner" TargetType="Rectangle" BasedOn="{StaticResource SideCorner}">
        <Setter Property="Width" Value="16.2"/>
    </Style>
    
    <Style x:Key="FrontHole" TargetType="Rectangle" BasedOn="{StaticResource SideHole}">
        <Setter Property="Margin" Value="6.4,2"/>
    </Style>
    
    <Style x:Key="RoofCorner" TargetType="Rectangle" BasedOn="{StaticResource SideCorner}">
        <Setter Property="Width" Value="17.8"/>
        <Setter Property="Height" Value="16.2"/>
        <Setter Property="Fill" Value="#50802E00"/>
    </Style>
    
    <Style x:Key="RoofHole" TargetType="Rectangle" BasedOn="{StaticResource SideHole}">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="RadiusX" Value="2.5"/>
        <Setter Property="RadiusY" Value="2.5"/>
        <Setter Property="Margin" Value="4.5,5.5"/>
    </Style>
    
    <local:StripeViewportSizeConverter x:Key="StripeViewportSizeConverter"/>
    
    <DataTemplate x:Key="SideTemplate">
        <Grid>
            <Rectangle Style="{StaticResource SideCorner}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Rectangle Style="{StaticResource SideCorner}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
            <Rectangle Style="{StaticResource SideCorner}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <Rectangle Style="{StaticResource SideCorner}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            <Rectangle Style="{StaticResource SurfaceDecolor}"/>
            <Rectangle x:Name="stripeRgion" Margin="15,6,15,23">
                <Rectangle.Fill>
                    <VisualBrush TileMode="Tile" Stretch="None" AlignmentX="Right" ViewportUnits="Absolute">
                        <VisualBrush.Viewport>
                            <MultiBinding Converter="{StaticResource StripeViewportSizeConverter}">
                                <MultiBinding.ConverterParameter>
                                    <sys:Double>27.7</sys:Double>
                                </MultiBinding.ConverterParameter>
                                <Binding Path="ActualWidth" ElementName="stripeRgion"/>
                                <Binding Path="ActualHeight" ElementName="stripeRgion"/>
                            </MultiBinding>
                        </VisualBrush.Viewport>
                        <VisualBrush.Visual>
                            <Border Width="{Binding Fill.Viewport.Width, ElementName=stripeRgion}"
                                    Height="{Binding ActualHeight, ElementName=stripeRgion}" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="0.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="1" Fill="Black" Opacity="0.2"/>
                                    <Rectangle Grid.Column="3" Fill="White" Opacity="0.2"/>
                                    <Rectangle Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Top" Height="10" Margin="-3,-6">
                                        <Rectangle.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#60000000" Offset="0"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="10" Margin="-3,-6">
                                        <Rectangle.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#60FFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                            </Border>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle Height="17" Margin="17.2,0" VerticalAlignment="Bottom">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#66000000"/>
                        <GradientStop Color="#22000000" Offset="0.5"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle Style="{StaticResource SideHole}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Rectangle Style="{StaticResource SideHole}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
            <Rectangle Style="{StaticResource SideHole}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <Rectangle Style="{StaticResource SideHole}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>
    </DataTemplate>

    <Style TargetType="{x:Type local:ContainerTexture}">
        <Setter Property="RoofTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid>
                        <Rectangle Style="{StaticResource RoofCorner}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource RoofCorner}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource RoofCorner}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource RoofCorner}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource SurfaceDecolor}"/>
                        <Rectangle x:Name="stripeRgion" Margin="28,8" Opacity="0.2">
                            <Rectangle.Fill>
                                <VisualBrush TileMode="Tile" Stretch="None" AlignmentX="Center" ViewportUnits="Absolute">
                                    <VisualBrush.Viewport>
                                        <MultiBinding Converter="{StaticResource StripeViewportSizeConverter}">
                                            <MultiBinding.ConverterParameter>
                                                <sys:Double>27.7</sys:Double>
                                            </MultiBinding.ConverterParameter>
                                            <Binding Path="ActualWidth" ElementName="stripeRgion"/>
                                            <Binding Path="ActualHeight" ElementName="stripeRgion"/>
                                        </MultiBinding>
                                    </VisualBrush.Viewport>
                                    <VisualBrush.Visual>
                                        <Grid Width="18"
                                              Height="{Binding ActualHeight, ElementName=stripeRgion}">
                                            <Border BorderBrush="White" BorderThickness="4,4,0,0" CornerRadius="9" Opacity="1"/>
                                            <Border BorderBrush="Black" BorderThickness="0,0,4,4" CornerRadius="9" Opacity="1"/>
                                        </Grid>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Style="{StaticResource RoofHole}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource RoofHole}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource RoofHole}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource RoofHole}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="LeftSideTemplate">
            <Setter.Value>
                <DataTemplate>
                    <ContentPresenter ContentTemplate="{StaticResource SideTemplate}"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="FloorTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Rectangle Fill="#80000000" Stroke="Black" StrokeThickness="100" Margin="-50">
                        <Rectangle.Effect>
                            <BlurEffect Radius="200"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="RightSideTemplate">
            <Setter.Value>
                <DataTemplate>
                    <ContentPresenter ContentTemplate="{StaticResource SideTemplate}" RenderTransformOrigin="0.5,0">
                        <ContentPresenter.RenderTransform>
                            <ScaleTransform ScaleX="-1"/>
                        </ContentPresenter.RenderTransform>
                    </ContentPresenter>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="DoorTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource SurfaceDecolor}"/>

                        <Grid Margin="16,30">
                            <Grid.Resources>
                                <DataTemplate x:Key="DoorIndent">
                                    <Grid ClipToBounds="True">
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                    <GradientStop Color="#33000000" Offset="0.3"/>
                                                    <GradientStop Color="#00000000" Offset="0.3"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="0.7"/>
                                                    <GradientStop Color="#33FFFFFF" Offset="0.7"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Rectangle Width="10" HorizontalAlignment="Left" Margin="-6">
                                            <Rectangle.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#40000000" Offset="0"/>
                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Rectangle Width="10" HorizontalAlignment="Right" Margin="-6">
                                            <Rectangle.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#40FFFFFF" Offset="0"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </Grid>
                                </DataTemplate>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="17"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.4*"/>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="2.2*"/>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="0.8*"/>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="0.8*"/>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="2.2*"/>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="0.4*"/>
                            </Grid.RowDefinitions>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="0" Grid.Row="1"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="0" Grid.Row="3"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="0" Grid.Row="5"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="0" Grid.Row="7"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="0" Grid.Row="9"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="2" Grid.Row="1"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="2" Grid.Row="3"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="2" Grid.Row="5"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="2" Grid.Row="7"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorIndent}" Grid.Column="2" Grid.Row="9"/>
                        </Grid>

                        <Grid Grid.IsSharedSizeScope="True" Margin="4,12,4,16" ClipToBounds="False">
                            <Grid.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Black"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Style>
                                <DataTemplate x:Key="DoorHinge">
                                    <Grid Margin="-2,0" Width="13">
                                        <Border BorderBrush="#80FFFFFF" BorderThickness="0,1,0,0"/>
                                        <Border BorderBrush="#80000000" BorderThickness="0,0,0,1"/>
                                    </Grid>
                                </DataTemplate>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="8" SharedSizeGroup="Hinge"/>
                                <RowDefinition SharedSizeGroup="Hinge"/>
                                <RowDefinition/>
                                <RowDefinition SharedSizeGroup="Hinge"/>
                                <RowDefinition/>
                                <RowDefinition SharedSizeGroup="Hinge"/>
                                <RowDefinition/>
                                <RowDefinition SharedSizeGroup="Hinge"/>
                                <RowDefinition SharedSizeGroup="Hinge"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" BorderThickness="4,4,0,0"/>
                            <Border Grid.Row="2" BorderThickness="4,0,0,0"/>
                            <Border Grid.Row="4" BorderThickness="4,0,0,0"/>
                            <Border Grid.Row="6" BorderThickness="4,0,0,0"/>
                            <Border Grid.Row="8" BorderThickness="4,0,0,4"/>
                            <Border Grid.Column="1" Grid.RowSpan="9"/>
                            <Border Grid.Column="2" Grid.Row="0" BorderThickness="0,4,4,0"/>
                            <Border Grid.Column="2" Grid.Row="2" BorderThickness="0,0,4,0"/>
                            <Border Grid.Column="2" Grid.Row="4" BorderThickness="0,0,4,0"/>
                            <Border Grid.Column="2" Grid.Row="6" BorderThickness="0,0,4,0"/>
                            <Border Grid.Column="2" Grid.Row="8" BorderThickness="0,0,4,4"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Row="1" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Row="3" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Row="5" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Row="7" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Right"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Column="2" Grid.Row="3" HorizontalAlignment="Right"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Column="2" Grid.Row="5" HorizontalAlignment="Right"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHinge}" Grid.Column="2" Grid.Row="7" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="20,8,20,12">
                            <Grid.Resources>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Fill">
                                        <Setter.Value>
                                            <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                                                <GradientStop Color="#FF808080"/>
                                                <GradientStop Color="#FFDDDDDD" Offset="0.5"/>
                                                <GradientStop Color="#FF808080" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <DataTemplate x:Key="DoorHandle">
                                    <Grid Margin="3,0" Width="30" Background="#FFAAAAAA">
                                        <Border BorderBrush="#FFCCCCCC" BorderThickness="0,1,0,0"/>
                                        <Border BorderBrush="#FF707070" BorderThickness="0,0,0,1"/>
                                    </Grid>
                                </DataTemplate>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Height" Value="4"/>
                                    <Setter Property="VerticalAlignment" Value="Bottom"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="1" Width="5" HorizontalAlignment="Left"/>
                            <Rectangle Grid.Column="1" Width="5" HorizontalAlignment="Right"/>
                            <Rectangle Grid.Column="3" Width="5" HorizontalAlignment="Left"/>
                            <Rectangle Grid.Column="3" Width="5" HorizontalAlignment="Right"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHandle}" Grid.Column="1" Margin="0,0,0,65" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHandle}" Grid.Column="1" Margin="0,0,0,50" HorizontalAlignment="Right"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHandle}" Grid.Column="3" Margin="0,0,0,50" HorizontalAlignment="Left"/>
                            <ContentPresenter ContentTemplate="{StaticResource DoorHandle}" Grid.Column="3" Margin="0,0,0,65" HorizontalAlignment="Right"/>
                        </Grid>

                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Rectangle Fill="Black" Width="18" Margin="17,0" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                        <Rectangle Fill="Black" Width="18" Margin="17,0" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                        <Rectangle Fill="Black" Height="3" VerticalAlignment="Bottom" Margin="17,0"/>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="FrontTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontCorner}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource SurfaceDecolor}"/>
                        <Rectangle x:Name="stripeRgion" Margin="11,6,11,23">
                            <Rectangle.Fill>
                                <VisualBrush TileMode="Tile" Stretch="None" AlignmentX="Center" ViewportUnits="Absolute">
                                    <VisualBrush.Viewport>
                                        <MultiBinding Converter="{StaticResource StripeViewportSizeConverter}">
                                            <MultiBinding.ConverterParameter>
                                                <sys:Double>24.7</sys:Double>
                                            </MultiBinding.ConverterParameter>
                                            <Binding Path="ActualWidth" ElementName="stripeRgion"/>
                                            <Binding Path="ActualHeight" ElementName="stripeRgion"/>
                                        </MultiBinding>
                                    </VisualBrush.Viewport>
                                    <VisualBrush.Visual>
                                        <Grid Width="{Binding Fill.Viewport.Width, ElementName=stripeRgion}"
                                              Height="{Binding ActualHeight, ElementName=stripeRgion}" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="0.5*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="0.5*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="1" Fill="Black" Opacity="0.4"/>
                                            <Rectangle Grid.Column="3" Fill="White" Opacity="0.4"/>
                                            <Rectangle Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Top" Height="6" Margin="-1,-3">
                                                <Rectangle.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#90000000" Offset="0.5"/>
                                                        <GradientStop Color="#00000000" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <Rectangle Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="6" Margin="-1,-3">
                                                <Rectangle.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#90FFFFFF" Offset="0.5"/>
                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                        </Grid>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Height="17" Margin="15.9,0" VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#66000000"/>
                                    <GradientStop Color="#22000000" Offset="0.5"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Fill="Black" Height="13" VerticalAlignment="Bottom" Margin="74,0"/>
                        <Rectangle Fill="Black" Width="18" Margin="17,0" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                        <Rectangle Fill="Black" Width="18" Margin="17,0" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                        <Rectangle Fill="Black" Height="3" VerticalAlignment="Bottom" Margin="17,0"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <Rectangle Style="{StaticResource FrontHole}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ContainerTexture}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding TextureSize.X, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                            <ColumnDefinition Width="{Binding TextureSize.Y, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{Binding TextureSize.Y, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                            <RowDefinition Height="{Binding TextureSize.Z, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                            <RowDefinition Height="{Binding TextureSize.Y, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                            <RowDefinition Height="{Binding TextureSize.Z, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                        </Grid.RowDefinitions>
                        <ContentPresenter Style="{StaticResource SurfacePresenter}" ContentTemplate="{TemplateBinding RoofTemplate}"/>
                        <ContentPresenter Style="{StaticResource SurfacePresenter}" ContentTemplate="{TemplateBinding LeftSideTemplate}" Grid.Row="1"/>
                        <ContentPresenter Style="{StaticResource SurfacePresenter}" ContentTemplate="{TemplateBinding FloorTemplate}" Grid.Row="2"/>
                        <ContentPresenter Style="{StaticResource SurfacePresenter}" ContentTemplate="{TemplateBinding RightSideTemplate}" Grid.Row="3"/>
                        <ContentPresenter Style="{StaticResource SurfacePresenter}" ContentTemplate="{TemplateBinding DoorTemplate}" Grid.Column="1" Grid.Row="1"/>
                        <ContentPresenter Style="{StaticResource SurfacePresenter}" ContentTemplate="{TemplateBinding FrontTemplate}" Grid.Column="1" Grid.Row="3"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
